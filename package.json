{
  "name": "worshipflow",
  "productName": "WorshipFlow",
  "version": "1.0.4",
  "description": "Local-first worship presentation app inspired by ProPresenter and G-Presenter",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "package:win": "npm run build && npx --yes electron-builder --win nsis --x64 --publish never",
    "release": "npm run package:win"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "pdf-to-png-converter": "^4.1.1",
    "pdfjs-dist": "^6.1.200",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.7",
    "ws": "^8.21.0",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^28.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.alabworship.worshipflow",
    "productName": "WorshipFlow",
    "asar": true,
    "files": [
      "dist/**/*",
      "src/**/*",
      "package.json",
      "bible-data/**/*",
      "scripts/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
